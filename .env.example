# In-Alpes Chalet Services — backend environment.
# Copy to `.env` (git-ignored) and fill in. EVERY var is optional locally:
# when one is missing the backend degrades to a dev fallback (in-memory DB,
# console emails, in-process blobs, dev-open admin). See netlify/lib/env.ts.

# --- Neon (Postgres, EU/Frankfurt). Absent → in-memory store seeded from JSON.
NEON_DATABASE_URL=

# --- Neon Auth (Better Auth). Absent → password fallback / dev-open admin.
# NEON_AUTH_* keys per your Neon Auth setup go here.

# --- Fallback owner auth (before Neon Auth is wired). Both required together.
ADMIN_PASSWORD=
SESSION_SECRET=            # long random string; signs the session cookie

# Open the admin WITHOUT auth for local dev only. Requires an explicit opt-in and
# is ignored in any production/Netlify context — a missing secret never fails open.
# Leave UNSET everywhere except your own machine.
ALLOW_DEV_OPEN_AUTH=

# --- Netlify Blobs. Auto-injected on Netlify; set manually for edge/off-platform.
NETLIFY_BLOBS_SITE_ID=
NETLIFY_BLOBS_TOKEN=

# --- Resend (transactional email). Absent → emails logged to console.
RESEND_API_KEY=
EMAIL_FROM="In-Alpes <info@in-alpes.ch>"
OWNER_NOTIFICATION_EMAIL=info@in-alpes.ch

# --- Cloudinary (image uploads). Absent → sign-upload returns 503.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=in-alpes/apartments

# --- Misc
SITE_URL=https://in-alpes.ch
PREBOOKING_TTL_HOURS=48
